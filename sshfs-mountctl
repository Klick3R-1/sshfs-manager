#!/usr/bin/env python3
"""sshfs-mountctl — launcher. Delegates to the sshfs_mountctl package."""

import os
import sys

# Ensure the package directory (same dir as this script) is on the path
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

try:
    from sshfs_mountctl.__main__ import main
except ImportError as exc:
    print(f"Error: {exc}")
    print("Make sure 'textual' is installed:  pip install textual")
    sys.exit(1)

main()
